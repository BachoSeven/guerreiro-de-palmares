---
import Base from "../layouts/Base.astro";
import Welcome from "../components/general/Welcome.astro";
import LatestPosts from "../components/blog/LatestPosts.astro";
---

<Base>
	<main>
		<Welcome />
		<LatestPosts />
		<div class="container mx-auto max-w-screen-lg px-7 pb-14">
			<a href="/blog" class="inline-flex items-center rounded-full border border-pacamara-accent/30 bg-pacamara-accent/10 px-6 py-3 font-pacamara-space text-pacamara-accent transition-all duration-300 hover:-translate-y-0.5 hover:bg-pacamara-accent hover:text-white dark:border-pacamara-secondary/30 dark:bg-pacamara-secondary/10 dark:text-pacamara-secondary dark:hover:bg-pacamara-secondary dark:hover:text-pacamara-dark">
				Vedi tutti gli eventi
			</a>
		</div>
	</main>
</Base>
