---
import { Image } from 'astro:assets'
import slide1 from "../assets/slide-1.jpg";
import slide2 from "../assets/slide-2.jpg";
import slide3 from "../assets/slide-3.jpg";
import slide4 from "../assets/slide-4.jpg";
import slide5 from "../assets/slide-5.jpg";

import Base from "../layouts/Base.astro";

import { getCollection, getEntry } from "astro:content";

export async function getStaticPaths() {
  const pageEntries = await getCollection("page");

  return pageEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}
const { entry } = Astro.props;
entry.data.type = "blog";
const isGalleryPage = entry.slug === "galleria";
const isSongbookPage = entry.slug === "canzoni";
const galleryImages = [
  { src: slide1, alt: "Guerreiro di Palmares - immagine 1" },
  { src: slide2, alt: "Guerreiro di Palmares - immagine 2" },
  { src: slide3, alt: "Guerreiro di Palmares - immagine 3" },
  { src: slide4, alt: "Guerreiro di Palmares - immagine 4" },
  { src: slide5, alt: "Guerreiro di Palmares - immagine 5" },
];
const galleryCoverImage = entry.data.image ? [{ src: entry.data.image, alt: entry.data.title }] : [];
const galleryGridImages = [...galleryCoverImage, ...galleryImages];

const { Content } = await entry.render();
---

<Base postData={entry}>
  <article data-image-popup-root data-songbook={isSongbookPage ? "true" : undefined} class="px-5 sm:px-7 pt-6 sm:pt-10 mx-auto w-full max-w-screen-lg">
    <div class="mx-auto prose lg:prose-xl prose-headings:font-bold prose-headings:text-pacamara-dark prose-headings:mb-3 text-left">
      <h1 class="transition-all duration-300 dark:text-white">{entry.data.title}</h1>
    </div>

    {isGalleryPage ? (
      <section class="mt-8 sm:mt-10">
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-3">
          {galleryGridImages.map((image, index) => (
            <button type="button" data-image-popup-trigger class={`group overflow-hidden rounded-[18px] bg-white shadow-sm transition-transform duration-300 hover:-translate-y-1 dark:bg-pacamara-dark ${index === 0 ? 'sm:col-span-2 xl:col-span-2' : ''}`}>
              <Image src={image.src} alt={image.alt} class="h-full w-full object-cover image-shine" />
            </button>
          ))}
        </div>
      </section>
    ) : (
      <>
        {entry.data.image && (
          <button type="button" data-image-popup-trigger class="mx-auto mt-8 sm:mt-10 block w-full max-w-3xl cursor-zoom-in">
            <Image
              src={entry.data.image}
              width={entry.data.image.width}
              height={entry.data.image.height}
              alt={entry.data.title}
              loading="eager"
              decoding="sync"
              class="block relative w-full h-auto max-h-[58vh] object-cover shadow-sm rounded-[15px] image-shine"
            />
          </button>
        )}
        <div class="
            lg:px-0 pt-8 sm:pt-10 mb-5 mx-auto
            prose lg:prose-xl
            prose-headings:transition-all prose-headings:duration-300 prose-headings:font-pacamara-space prose-headings:font-bold prose-headings:text-pacamara-accent prose-headings:mb-0 prose-headings:pb-3 prose-headings:mt-6
            prose-p:transition-all prose-p:duration-300 prose-p:text-pacamara-primary/80 
            prose-li:transition-all prose-li:duration-300 prose-li:text-pacamara-primary/80
            prose-td:transition-all prose-td:duration-300 prose-td:text-pacamara-primary/80
            prose-a:underline prose-a:font-semibold prose-a:transition-all prose-a:duration-300 prose-a:text-pacamara-accent hover:prose-a:text-pacamara-dark
            prose-strong:transition-all prose-strong:duration-300 prose-strong:font-bold
            prose-hr:transition-all prose-hr:duration-300 prose-hr:border-pacamara-secondary/40
            prose-img:rounded-lg prose-img:mx-auto prose-img:w-full prose-img:max-w-3xl prose-img:h-auto prose-img:max-h-[58vh] prose-img:object-cover
            prose-code:transition-all prose-code:duration-300 prose-code:text-pacamara-dark
            dark:prose-headings:text-pacamara-accent dark:prose-p:text-white/70 dark:prose-a:text-white dark:hover:prose-a:text-pacamara-accent dark:prose-strong:text-white dark:prose-li:text-white dark:prose-code:text-white dark:prose-td:text-white/70 dark:prose-hr:border-pacamara-accent/30 dark:prose-tr:border-pacamara-accent/30 dark:prose-thead:border-pacamara-accent/30
        ">
          <Content />
        </div>
      </>
    )}
</article>

{entry.data.image && (
  <dialog data-image-popup class="image-popup">
    <div class="relative overflow-hidden rounded-[18px]">
      <button type="button" data-image-popup-close aria-label="Chiudi immagine" class="absolute right-3 top-3 z-10 flex h-9 w-9 items-center justify-center rounded-full bg-white/90 text-xl text-pacamara-dark shadow-lg transition hover:bg-pacamara-accent hover:text-white dark:bg-pacamara-dark/90 dark:text-white">
        ×
      </button>
      <img data-image-popup-image alt={entry.data.title} class="block w-auto max-w-full rounded-[18px] object-contain" />
    </div>
  </dialog>
  <script is:inline>
    const articleRoot = document.querySelector('[data-image-popup-root]');
    const imagePopup = document.querySelector('[data-image-popup]');
    const imagePopupImage = imagePopup?.querySelector('[data-image-popup-image]');
    const imagePopupClose = imagePopup?.querySelector('[data-image-popup-close]');

    const openImagePopup = (sourceImage) => {
      if (!(imagePopup instanceof HTMLDialogElement) || !(imagePopupImage instanceof HTMLImageElement) || !(sourceImage instanceof HTMLImageElement)) {
        return;
      }

      imagePopupImage.src = sourceImage.currentSrc || sourceImage.src;
      imagePopupImage.alt = sourceImage.alt || '';
      imagePopupImage.srcset = sourceImage.srcset || '';
      imagePopupImage.sizes = sourceImage.sizes || '';

      if (!imagePopup.open) {
        imagePopup.showModal();
      }
    };

    articleRoot?.addEventListener('click', (event) => {
      const trigger = event.target.closest?.('[data-image-popup-trigger]');
      if (trigger) {
        event.preventDefault();
        openImagePopup(trigger.querySelector('img'));
      }
    });

    imagePopupClose?.addEventListener('click', () => imagePopup?.close());
    imagePopup?.addEventListener('click', (event) => {
      if (event.target === imagePopup) {
        imagePopup.close();
      }
    });
  </script>
)}

{isSongbookPage && (
  <script is:inline>
    const initSongbookInteractions = () => {
      const songbookRoot = document.querySelector('[data-songbook="true"]');
      if (!(songbookRoot instanceof HTMLElement) || songbookRoot.dataset.songbookBound === 'true') {
        return;
      }

      songbookRoot.dataset.songbookBound = 'true';
      const songAudios = Array.from(songbookRoot.querySelectorAll('audio'));

      const findLyricsPanel = (audioElement) => {
        if (!(audioElement instanceof HTMLAudioElement)) {
          return null;
        }

        let nextElement = audioElement.nextElementSibling;
        while (nextElement && nextElement.tagName !== 'DETAILS') {
          nextElement = nextElement.nextElementSibling;
        }

        return nextElement instanceof HTMLDetailsElement ? nextElement : null;
      };

      songAudios.forEach((audioElement) => {
        audioElement.addEventListener('play', () => {
          const lyricsPanel = findLyricsPanel(audioElement);
          if (!lyricsPanel) {
            return;
          }

          if (!lyricsPanel.open) {
            lyricsPanel.open = true;
          }

          lyricsPanel.classList.remove('song-lyrics--auto-open');
          requestAnimationFrame(() => {
            lyricsPanel.classList.add('song-lyrics--auto-open');
          });
        });
      });
    };

    initSongbookInteractions();
    document.addEventListener('astro:after-swap', initSongbookInteractions);
  </script>
)}

</Base>
