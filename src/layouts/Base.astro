---
import { ViewTransitions } from 'astro:transitions';
import SeoHead from "../components/general/SeoHead.astro"
import Header from "../components/general/Header.astro"
import Footer from "../components/general/Footer.astro"
import '../css/style.css';

const { postData } = Astro.props;
---
<!doctype html>
<html lang="en">

<head>
    <script is:inline>
        const setDarkMode = () => {
            if (localStorage.darkMode === 'true' || (!('darkMode' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark')
                localStorage.darkMode = 'true';
            } else {
                document.documentElement.classList.remove('dark')
                localStorage.darkMode = 'false';
            }
        }

        setDarkMode();
        // Runs on view transitions navigation
        document.addEventListener('astro:after-swap', setDarkMode);
    </script>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="view-transition" content="same-origin" />
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="./rss.xml" />
    <SeoHead postData={postData} />
    <link rel="preload" href="/fonts/inter-v12-latin_latin-ext-regular.woff2" as="font" crossorigin>
    <link rel="preload" href="/fonts/inter-v12-latin_latin-ext-700.woff2" as="font" crossorigin>
    <link rel="preload" href="/fonts/space-grotesk-v15-latin_latin-ext-regular.woff2" as="font" crossorigin>
    <link rel="preload" href="/fonts/space-grotesk-v15-latin_latin-ext-600.woff2" as="font" crossorigin>
    <link rel="preload" href="/fonts/space-grotesk-v15-latin_latin-ext-700.woff2" as="font" crossorigin>
    <ViewTransitions />

</head>

<body class="font-pacamara-inter transition-all duration-300 bg-white dark:bg-pacamara-dark">
    <Header />
    <slot />

    <Footer />

    <script is:inline>
        const initImagePopups = () => {
            document.querySelectorAll('[data-image-popup-root]').forEach((root) => {
                if (!(root instanceof HTMLElement) || root.dataset.imagePopupBound === 'true') {
                    return;
                }

                const popup = document.querySelector('[data-image-popup]');
                const popupImage = popup?.querySelector('[data-image-popup-image]');
                const popupClose = popup?.querySelector('[data-image-popup-close]');

                if (!(popup instanceof HTMLDialogElement) || !(popupImage instanceof HTMLImageElement)) {
                    return;
                }

                root.dataset.imagePopupBound = 'true';

                const openPopup = (sourceImage) => {
                    if (!(sourceImage instanceof HTMLImageElement)) {
                        return;
                    }

                    popupImage.src = sourceImage.currentSrc || sourceImage.src;
                    popupImage.alt = sourceImage.alt || '';
                    popupImage.srcset = sourceImage.srcset || '';
                    popupImage.sizes = sourceImage.sizes || '';

                    if (!popup.open) {
                        popup.showModal();
                    }
                };

                root.addEventListener('click', (event) => {
                    const trigger = event.target.closest?.('[data-image-popup-trigger]');
                    if (!trigger) {
                        return;
                    }

                    event.preventDefault();
                    openPopup(trigger.querySelector('img'));
                });

                popupClose?.addEventListener('click', () => popup.close());
                popup.addEventListener('click', (event) => {
                    if (event.target === popup) {
                        popup.close();
                    }
                });
            });
        };

        const runImagePopupInit = () => {
            initImagePopups();
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', runImagePopupInit, { once: true });
        } else {
            runImagePopupInit();
        }

        document.addEventListener('astro:after-swap', initImagePopups);
    </script>
</body>
</html>
